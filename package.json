{
  "name": "gamepay-event-engine",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node -r reflect-metadata src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d"
  },
  "keywords": [
    "payment",
    "event-sourcing",
    "cqrs",
    "bullmq",
    "typescript"
  ],
  "author": "SeongTaeHwang",
  "license": "MIT",
  "description": "Event-driven payment engine with BullMQ, CQRS, and event sourcing - replacing production while-true polling pattern",
  "dependencies": {
    "bullmq": "^5.75.2",
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "morgan": "^1.10.1",
    "mysql2": "^3.22.2",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "tsyringe": "^4.10.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@testcontainers/mysql": "^11.14.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "testcontainers": "^11.14.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
